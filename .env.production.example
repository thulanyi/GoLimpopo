# Copy to your secret manager or deployment environment.
# This profile is strict by design for internet-facing production.

SECRET_KEY=replace-with-strong-random-secret
FLASK_ENV=production
MAGAYISA_PRODUCTION=1
MAGAYISA_DEBUG=0

MAGAYISA_TRUST_PROXY=1
MAGAYISA_PROXY_X_FOR=1
MAGAYISA_PROXY_X_PROTO=1
MAGAYISA_PROXY_X_HOST=1
MAGAYISA_PROXY_X_PORT=1

MAGAYISA_SESSION_COOKIE_SECURE=1
MAGAYISA_SESSION_SAMESITE=Lax

# Required in production
MAGAYISA_POSTGRES_DSN=postgresql://user:password@host:5432/magayisa
MAGAYISA_REDIS_URL=redis://host:6379/0

# Keep beta guardrail on until full launch
MAGAYISA_BETA_MODE=1
MAGAYISA_BETA_MAX_DAILY_ACTIVE_USERS=200
MAGAYISA_BETA_ACTIVITY_WINDOW_SECONDS=86400

MAGAYISA_SENTRY_DSN=
MAGAYISA_SENTRY_TRACES_SAMPLE_RATE=0.1

# Use live payment credentials for production
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=0
PAYFAST_SIGN_REQUESTS=1
PAYFAST_TEST_MODE_FALLBACK=0

MAGAYISA_PUBLIC_BASE_URL=https://your-domain.example.com

# Required: do not leave blank
MAGAYISA_ADMIN_EMAIL=admin@your-domain.example.com
MAGAYISA_ADMIN_PASSWORD=replace-with-strong-admin-password

# Gunicorn runtime defaults
PORT=8000
WEB_CONCURRENCY=4
